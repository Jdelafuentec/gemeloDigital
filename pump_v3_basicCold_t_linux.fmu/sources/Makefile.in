# Makefile generated by OpenModelica
CC=@CC@
AR=@AR@
CFLAGS=@CFLAGS@
LD=$(CC) -shared
# define OMC_LDFLAGS_LINK_TYPE env variable to override this
OMC_LDFLAGS_LINK_TYPE=static
LDFLAGS=@LDFLAGS@ @LIBS@
DLLEXT=@DLLEXT@
NEED_RUNTIME=@NEED_RUNTIME@
NEED_DGESV=@NEED_DGESV@
NEED_CMINPACK=@NEED_CMINPACK@
NEED_SUNDIALS=@NEED_SUNDIALS@
FMIPLATFORM=@FMIPLATFORM@
# Note: Simulation of the fmu with dymola does not work with -finline-small-functions (enabled by most optimization levels)
CPPFLAGS=@CPPFLAGS@
override CPPFLAGS += -DFMI2_OVERRIDE_FUNCTION_PREFIX

override CPPFLAGS += "-I/root/.openmodelica/libraries/Modelica 4.0.0+maint.om/Resources/C-Sources"

CFILES = pump_v3_basicCold_t.c \
         pump_v3_basicCold_t_functions.c \
         pump_v3_basicCold_t_records.c \
         pump_v3_basicCold_t_01exo.c \
         pump_v3_basicCold_t_02nls.c \
         pump_v3_basicCold_t_03lsy.c \
         pump_v3_basicCold_t_04set.c \
         pump_v3_basicCold_t_05evt.c \
         pump_v3_basicCold_t_06inz.c \
         pump_v3_basicCold_t_07dly.c \
         pump_v3_basicCold_t_08bnd.c \
         pump_v3_basicCold_t_09alg.c \
         pump_v3_basicCold_t_10asr.c \
         pump_v3_basicCold_t_11mix.c \
         pump_v3_basicCold_t_12jac.c \
         pump_v3_basicCold_t_13opt.c \
         pump_v3_basicCold_t_14lnz.c \
         pump_v3_basicCold_t_15syn.c \
         pump_v3_basicCold_t_16dae.c \
         pump_v3_basicCold_t_17inl.c \
         pump_v3_basicCold_t_18spd.c \
         pump_v3_basicCold_t_init_fmu.c \
         pump_v3_basicCold_t_FMU.c \
         pump_v3_basicCold_t_08bnd_part0.c \
         pump_v3_basicCold_t_08bnd_part1.c \
         pump_v3_basicCold_t_08bnd_part2.c
OFILES=$(CFILES:.c=.o)

RUNTIMEDIR=.
ifneq ($(NEED_DGESV),)
DGESV_OBJS = ./external_solvers/dgesv.o ./external_solvers/dgetrf.o ./external_solvers/dgetri.o ./external_solvers/dtrtri.o ./external_solvers/dtrti2.o ./external_solvers/dlamch.o ./external_solvers/ilaenv.o ./external_solvers/xerbla.o ./external_solvers/dgetf2.o ./external_solvers/dgetrs.o ./external_solvers/dlaswp.o ./external_solvers/ieeeck.o ./external_solvers/iparmq.o ./external_solvers/dgemm.o ./external_solvers/dger.o ./external_solvers/dgemv.o ./external_solvers/dscal.o ./external_solvers/dswap.o ./external_solvers/dtrsm.o ./external_solvers/dtrmm.o ./external_solvers/dtrmv.o ./external_solvers/idamax.o ./external_solvers/lsame.o ./external_solvers/i_nint.o ./external_solvers/pow_di.o ./external_solvers/s_cmp.o ./external_solvers/s_copy.o ./external_solvers/s_cat.o ./external_solvers/F77_aloc.o ./external_solvers/exit_.o
endif
ifneq ($(NEED_CMINPACK),)
CMINPACK_OBJS=./external_solvers/enorm_.o ./external_solvers/hybrj_.o ./external_solvers/dpmpar_.o ./external_solvers/qrfac_.o ./external_solvers/qform_.o ./external_solvers/dogleg_.o ./external_solvers/r1updt_.o ./external_solvers/r1mpyq_.o
endif
ifneq ($(NEED_RUNTIME),)
RUNTIMEFILES=fmi-export/fmu2_model_interface.o fmi-export/fmu_read_flags.o ./gc/memory_pool.o ./gc/omc_gc.o ./util/base_array.o ./util/boolean_array.o ./util/context.o ./util/division.o ./util/doubleEndedList.o ./util/generic_array.o ./util/index_spec.o ./util/integer_array.o ./util/list.o ./util/modelica_string_lit.o ./util/modelica_string.o ./util/ModelicaUtilities.o ./util/omc_error.o ./util/omc_file.o ./util/omc_init.o ./util/omc_mmap.o ./util/omc_msvc.o ./util/omc_numbers.o ./util/parallel_helper.o ./util/rational.o ./util/real_array.o ./util/ringbuffer.o ./util/simulation_options.o ./util/string_array.o ./util/utility.o ./util/varinfo.o ./math-support/pivot.o ./simulation/arrayIndex.o ./simulation/jacobian_util.o ./simulation/omc_simulation_util.o ./simulation/options.o ./simulation/simulation_info_json.o ./simulation/simulation_omc_assert.o ./simulation/solver/delay.o ./simulation/solver/fmi_events.o ./simulation/solver/model_help.o ./simulation/solver/omc_math.o ./simulation/solver/spatialDistribution.o ./simulation/solver/stateset.o ./simulation/solver/synchronous.o ./simulation/solver/initialization/initialization.o ./meta/meta_modelica_catch.o ./simulation/solver/nonlinearSolverHomotopy.o ./simulation/solver/nonlinearSolverHybrd.o ./simulation/solver/nonlinearValuesList.o ./simulation/solver/nonlinearSystem.o $(DGESV_OBJS) $(CMINPACK_OBJS)
endif
ifneq ($(NEED_SUNDIALS),)
FMISUNDIALSFILES=
LDFLAGS+=-Wl,-Bstatic -lsundials_cvode -lsundials_nvecserial -Wl,-Bdynamic
endif

PHONY: pump_v3_basicCold_t_FMU
pump_v3_basicCold_t_FMU: nozip
	cd .. && rm -f ../pump_v3_basicCold_t.fmu && zip -r ../pump_v3_basicCold_t.fmu *
nozip: pump_v3_basicCold_t_functions.h pump_v3_basicCold_t_literals.h $(OFILES) $(RUNTIMEFILES) $(FMISUNDIALSFILES)
	mkdir -p ../binaries/$(FMIPLATFORM)
ifeq (@LIBTYPE_DYNAMIC@,1)
	$(LD) -o pump_v3_basicCold_t$(DLLEXT) $(OFILES) $(RUNTIMEFILES) $(FMISUNDIALSFILES) -L"/work"  "-L/usr/bin/../lib/x86_64-linux-gnu/omc" -Wl,-rpath="/usr/bin/../lib/x86_64-linux-gnu/omc" "-L/usr/bin/../lib/" -Wl,-rpath="/usr/bin/../lib/" "-L/root/.openmodelica/binaries/Modelica" -Wl,-rpath="/root/.openmodelica/binaries/Modelica" "-L/root/.openmodelica/libraries/Modelica 4.0.0+maint.om/Resources/Library/" -Wl,-rpath="/root/.openmodelica/libraries/Modelica 4.0.0+maint.om/Resources/Library/" "-L/root/.openmodelica/libraries/Modelica 4.0.0+maint.om/Resources/Library/x86_64-linux" -Wl,-rpath="/root/.openmodelica/libraries/Modelica 4.0.0+maint.om/Resources/Library/x86_64-linux" "-L/root/.openmodelica/libraries/Modelica 4.0.0+maint.om/Resources/Library/linux64" -Wl,-rpath="/root/.openmodelica/libraries/Modelica 4.0.0+maint.om/Resources/Library/linux64" "-L/root/.openmodelica/libraries/Modelica 4.0.0+maint.om/Resources/Library" -Wl,-rpath="/root/.openmodelica/libraries/Modelica 4.0.0+maint.om/Resources/Library" -lModelicaExternalC @BDYNAMIC@ $(LDFLAGS)
	cp pump_v3_basicCold_t$(DLLEXT) pump_v3_basicCold_t_FMU.libs ../binaries/$(FMIPLATFORM)/
endif
	head -n20 Makefile > ../resources/$(FMIPLATFORM).summary
ifeq (@LIBTYPE_STATIC@,1)
	rm -f pump_v3_basicCold_t.a
	$(AR) -rsu pump_v3_basicCold_t.a $(OFILES) $(RUNTIMEFILES) $(FMISUNDIALSFILES)
	cp pump_v3_basicCold_t.a pump_v3_basicCold_t_FMU.libs ../binaries/$(FMIPLATFORM)/
endif
	$(MAKE) distclean
distclean: clean
	rm -f Makefile config.status config.log
clean:
	rm -f pump_v3_basicCold_t.def pump_v3_basicCold_t.o pump_v3_basicCold_t.a pump_v3_basicCold_t$(DLLEXT) $(MAINOBJ) $(OFILES) $(RUNTIMEFILES) $(FMISUNDIALSFILES)